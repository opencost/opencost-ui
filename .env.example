# OpenCost API base URL. For local scoped views/RBAC, point this at costmodel.
VITE_BASE_API_URL="http://localhost:9003"

# Clerk authentication. Use your Clerk publishable key from the Clerk dashboard.
VITE_CLERK_PUBLISHABLE_KEY=""

# Optional: Clerk JWT template name if your API expects a custom token template.
VITE_CLERK_JWT_TEMPLATE=""

# Optional: Clerk organization role keys used for Settings access checks.
VITE_CLERK_ORG_ROLE_ADMIN="org:admin"
VITE_CLERK_ORG_ROLE_MEMBER="org:member"

# Dev only: bypass auth when no Clerk key is configured.
VITE_AUTH_DISABLED="false"

# Optional: legacy UI/dev mode.
VITE_LEGACY_MODE="false"
VITE_LEGACY_BASENAME="/legacy"